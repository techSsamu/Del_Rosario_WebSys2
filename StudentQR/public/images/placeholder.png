<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
  <!-- Background -->
  <rect width="200" height="200" fill="#ecf0f1"/>
  
  <!-- Head circle -->
  <circle cx="100" cy="60" r="30" fill="#bdc3c7"/>
  
  <!-- Body -->
  <ellipse cx="100" cy="130" rx="45" ry="50" fill="#bdc3c7"/>
  
  <!-- Icon -->
  <text x="100" y="150" font-size="60" font-family="Arial" text-anchor="middle" fill="#95a5a6">👤</text>
</svg>
